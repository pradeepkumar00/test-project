# Copy to config/local.json for local development (gitignored)
# cp Backend/config/local.example.json Backend/config/local.json

# Or override via environment variables in production (see Backend/config/custom-environment-variables.json):
#
# NODE_ENV=production
# PORT=5000
# ADMIN_PORT=5050
# APP_URL=https://bigfun.in
# MONGODB_URI=mongodb://127.0.0.1:27017/bigfun
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_PASSWORD=password
# REDIS_KEY_PREFIX=bigfun:
# JWT_SECRET=your-production-secret
# ADMIN_JWT_SECRET=your-admin-production-secret
#
# SMS / Twilio:
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_FROM=+1234567890
# TWILIO_COUNTRY_CODE=+91
#
# Wallet:
# UPI_ID=your-upi-id@bank
# MIN_DEPOSIT=100
# MIN_WITHDRAW=110
# REFERRAL_BONUS=50
